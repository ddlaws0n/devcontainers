# Example .npmrc for projects that fall back to npm.
# Copy to your project root.

# Block npm postinstall scripts by default. Run `npm install --ignore-scripts=false`
# explicitly when you really do want them to run.
ignore-scripts=true

# Reproducible installs.
package-lock=true

# Don't auto-install peer deps — surface conflicts instead.
auto-install-peers=false

# Quiet output.
fund=false
audit=false
