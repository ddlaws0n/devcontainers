# Tailscale opt-in override for the TS/JS devcontainer.
#
# Activate by copying this file to compose.override.yaml in the same directory.
# docker compose auto-merges compose.override.yaml when present — no other config
# changes needed.
#
# Required env (set in .env at the .devcontainer/ root, gitignored):
#   TS_AUTHKEY=tskey-auth-...   # ephemeral, tagged auth key
#   TS_HOSTNAME=my-devcontainer # optional, defaults to container hostname
#
# Generate an auth key at:
#   https://login.tailscale.com/admin/settings/keys
# Recommended flags: ephemeral, reusable, tagged (e.g. tag:devcontainer)

services:
  tailscale:
    image: tailscale/tailscale:latest
    hostname: ${TS_HOSTNAME:-tsjs-devcontainer}
    environment:
      TS_AUTHKEY: ${TS_AUTHKEY?TS_AUTHKEY is required for Tailscale variant}
      TS_USERSPACE: "true"
      TS_STATE_DIR: /var/lib/tailscale
      TS_EXTRA_ARGS: --ssh
    volumes:
      - tailscale-state:/var/lib/tailscale
    restart: unless-stopped

  dev:
    network_mode: service:tailscale
    depends_on:
      - tailscale

volumes:
  tailscale-state:
